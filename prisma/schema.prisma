generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth.js Models ────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  hostedRooms    Room[]            @relation("RoomHost")
  participations RoomParticipant[]
  watchHistory   WatchHistory[]
  ratings        MovieRating[]
  friendsOf      Friendship[]      @relation("FriendOf")
  friends        Friendship[]      @relation("FriendTo")
}


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Room System ───────────────────────────────────────

model Room {
  id        String   @id @default(cuid())
  code      String   @unique
  hostId    String
  status    String   @default("WAITING") // WAITING, SURVEYING, PROCESSING, RESULTS, DECIDED, CLOSED
  mode      String   @default("DISCOVER") // DISCOVER, SHORTLIST
  name      String?
  maxSize   Int      @default(8)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime

  host            User              @relation("RoomHost", fields: [hostId], references: [id])
  participants    RoomParticipant[]
  recommendations Recommendation[]
  candidates      RoomCandidate[]
}

// ─── Room Candidates (shortlist mode) ──────────────────

model RoomCandidate {
  id          String  @id @default(cuid())
  roomId      String
  tmdbMovieId Int
  title       String
  posterPath  String?
  releaseYear Int?
  voteAverage Float?
  overview    String?
  genreIds    String  @default("[]")

  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, tmdbMovieId])
}

// ─── Room Participants ─────────────────────────────────

model RoomParticipant {
  id              String   @id @default(cuid())
  roomId          String
  userId          String?
  guestName       String?
  surveyCompleted Boolean  @default(false)
  joinedAt        DateTime @default(now())

  room           Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user           User?           @relation(fields: [userId], references: [id])
  surveyResponse SurveyResponse?

  @@unique([roomId, userId])
}

// ─── Survey Responses ──────────────────────────────────

model SurveyResponse {
  id            String @id @default(cuid())
  participantId String @unique
  roomId        String

  // Stored as JSON strings for SQLite compatibility
  mood             String  // "chill" | "adventurous" | "intense" | "silly" | "romantic" | "mindBending"
  vibeWords        String  @default("[]") // JSON array of strings
  genreLikes       String  @default("[]") // JSON array of TMDB genre IDs
  genreDislikes    String  @default("[]") // JSON array of TMDB genre IDs
  decadeMin        Int?
  decadeMax        Int?
  maxRuntime       Int?
  minRating        Float?
  favoriteMovieIds String  @default("[]") // JSON array of TMDB movie IDs
  noSubtitles      Boolean @default(false)
  noBlackWhite     Boolean @default(false)
  noAnimation      Boolean @default(false)
  noHorror         Boolean @default(false)
  wildCard         String?

  createdAt DateTime @default(now())

  participant RoomParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

// ─── Recommendations ───────────────────────────────────

model Recommendation {
  id          String  @id @default(cuid())
  roomId      String
  tmdbMovieId Int
  title       String
  posterPath  String?
  overview    String?
  matchScore  Float
  explanation String
  rank        Int
  genreIds    String  @default("[]") // JSON array
  releaseYear Int?
  runtime     Int?
  voteAverage Float?
  votes       Int     @default(0)
  chosen      Boolean @default(false)

  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, rank])
}

// ─── Watch History ─────────────────────────────────────

model WatchHistory {
  id          String   @id @default(cuid())
  userId      String
  tmdbMovieId Int
  title       String
  posterPath  String?
  watchedAt   DateTime @default(now())
  roomId      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbMovieId])
}

// ─── Movie Ratings ─────────────────────────────────────

model MovieRating {
  id          String   @id @default(cuid())
  userId      String
  tmdbMovieId Int
  rating      Float
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbMovieId])
}

// ─── Friendships ───────────────────────────────────────

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user   User @relation("FriendOf", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendTo", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}
