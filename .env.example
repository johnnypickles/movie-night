# ─── Local dev (SQLite file) ────────────────────────────
# Used when TURSO_DATABASE_URL is NOT set.
DATABASE_URL="file:./dev.db"

# ─── Production (Turso / libSQL) ────────────────────────
# When TURSO_DATABASE_URL is set, the app uses Turso via the Prisma libSQL adapter.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# ─── Auth.js ────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ─── TMDB API - Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=""

# ─── App URL ────────────────────────────────────────────
# Vercel auto-populates VERCEL_URL; set this for local dev.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
